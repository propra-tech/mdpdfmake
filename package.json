{
  "name": "@propra/mdpdfmake",
  "version": "1.0.14",
  "description": "A Node.js library to convert Markdown to PDFMake Syntax",
  "main": "dist/index.js",
  "types": "src/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/propra-tech/mdpdfmake.git"
  },
  "keywords": [
    "markdown",
    "pdf",
    "pdfmake",
    "document",
    "converter"
  ],
  "author": "Sitaraman S",
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "nodemon --watch 'src/**/*.ts' --exec 'tsx' src/index.ts",
    "lint": "eslint .",
    "test": "node --import tsx --test 'src/**/*.spec.ts'",
    "prepublishOnly": "npm run lint && npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.0.10",
    "@types/pdfmake": "^0.2.13",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^9.39.2",
    "nodemon": "^3.1.11",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  },
  "dependencies": {
    "html-entities": "^2.6.0",
    "marked": "^17.0.1"
  },
  "peerDependencies": {
    "pdfmake": ">=0.2.0"
  },
  "homepage": "https://github.com/propra-tech/mdpdfmake#readme",
  "engines": {
    "node": ">=18.0.0"
  }
}
